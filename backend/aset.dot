digraph model_graph {
  // Dotfile by Django-Extensions graph_models
  // Created: 2026-07-08 23:01
  // Cli Options: aset --group-models --dot -o aset.dot

  fontname = "Roboto"
  fontsize = 8
  splines  = true
  rankdir = "TB"
  

  node [
    fontname = "Roboto"
    fontsize = 8
    shape = "plaintext"
  ]

  edge [
    fontname = "Roboto"
    fontsize = 8
  ]

  // Labels
